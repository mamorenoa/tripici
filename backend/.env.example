# Copy to .env and edit if you need to override the defaults below.

# Postgres connection. The default matches backend/docker-compose.yml, so
# you typically don't need to set this when running locally.
DATABASE_URL=postgresql+psycopg://tripinci:tripinci@localhost:5432/tripinci

# UUID used as the trip owner until real auth lands in slice 3.
DEV_OWNER_ID=00000000-0000-0000-0000-000000000001
