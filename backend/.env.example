# Copy to .env and edit if you need to override the defaults below.

# Postgres connection. The default matches backend/docker-compose.yml.
DATABASE_URL=postgresql+psycopg://tripinci:tripinci@localhost:5432/tripinci

# JWT signing secret. The code ships a dev default so the app boots out
# of the box. PRODUCTION MUST OVERRIDE THIS — otherwise tokens are
# forgeable. Generate with: `openssl rand -hex 32`.
AUTH_SECRET=dev-secret-change-in-production

# Access token lifetime in seconds (default: 24h).
AUTH_TOKEN_LIFETIME_SECONDS=86400

# Unsplash access key used by GET /cover to fetch trip cover images.
# Create a free app at https://unsplash.com/oauth/applications and copy
# its "Access Key". In production: `fly secrets set UNSPLASH_ACCESS_KEY=...`.
#
# It lives here (server-side) on purpose: the frontend must never carry it,
# since EXPO_PUBLIC_* vars are inlined into the public web bundle.
# If unset, /cover returns null and the app draws a gradient instead.
UNSPLASH_ACCESS_KEY=
