# Override the backend URL the Expo client should use.
#
# Useful when running on a physical device — Expo cannot reach the
# host machine's "localhost" from a phone. Copy this file to .env.local
# and set the value to your computer's LAN IP, for example:
#
#     EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# If left empty (or unset), the app falls back to:
#   - http://10.0.2.2:8000  on Android emulator
#   - http://localhost:8000 on web and iOS simulator
EXPO_PUBLIC_API_URL=

# NOTE: cover images no longer need anything here. The app asks its own
# backend (GET /cover), which holds the Unsplash key server-side — see
# UNSPLASH_ACCESS_KEY in backend/.env.example. Never put that key in an
# EXPO_PUBLIC_* var: those are inlined into the public web bundle.
